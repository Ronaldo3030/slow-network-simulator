{
  "manifest_version": 2,
  "name": "Request Delay Simulator",
  "version": "1.0.0",
  "description": "Simula lentidão de rede por regras de URL (exact/regex).",
  "permissions": [
    "storage",
    "webRequest",
    "webRequestBlocking",
    "<all_urls>"
  ],
  "background": {
    "scripts": ["background.js"]
  },
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "96": "icons/icon96.png"
  },
  "browser_action": {
    "default_title": "Request Delay",
    "default_popup": "popup/popup.html",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "96": "icons/icon96.png"
    }
  },
  "browser_specific_settings": {
    "gecko": {
      "id": "request-delay-simulator@example.com",
      "data_collection_permissions": {
        "required": ["none"]
      }
    }
  }
}
